{
  "name": "toWEBP",
  "version": "1.1.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "dev:all": "concurrently -n vite,electron -c cyan,yellow \"vite\" \"electron .\"",
    "package": "vite build && electron-builder",
    "package:mac": "vite build && electron-rebuild -f -w sharp && electron-builder --mac",
    "package:win": "vite build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.sanodzegg.towebp",
    "productName": "toWEBP",
    "mac": {
      "icon": "build-assets/icon.icns",
      "category": "public.app-category.graphics-design",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build-assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "files": [
      "dist/**",
      "electron/**",
      "main.js",
      "node_modules/**",
      "!node_modules/.cache/**",
      "!node_modules/.vite/**"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sharp/**/*",
      "**/node_modules/@img/**/*",
      "**/node_modules/detect-libc/**/*",
      "**/node_modules/ffmpeg-static/**/*"
    ],
    "npmRebuild": true,
    "buildDependenciesFromSource": false,
    "nativeRebuilder": "legacy"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jszip": "^3.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "shadcn": "^4.0.8",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  }
}
